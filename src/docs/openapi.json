{
  "openapi": "3.0.0",
  "info": {
    "title": "Spicy Noodle Management API",
    "version": "1.0.0",
    "description": "REST API cho hệ thống quản lý nhà hàng mỳ cay"
  },
  "servers": [
    {
      "url": "https://seoul-spicy-production.up.railway.app/api",
      "description": "Production server"
    },
    {
      "url": "http://localhost:8000/api",
      "description": "Local development"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "tags": [
    {"name": "Auth", "description": "Authentication"},
    {"name": "Users", "description": "User management (Admin)"},
    {"name": "Customers", "description": "Customer management"},
    {"name": "Categories", "description": "Category management"},
    {"name": "Products", "description": "Product management"},
    {"name": "Tables", "description": "Table management"},
    {"name": "Vouchers", "description": "Voucher management"}
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Đăng nhập",
        "description": "Đăng nhập và nhận JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": {"type": "string", "example": "0123456789"},
                  "password": {"type": "string", "example": "Pass@123"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Đăng nhập thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean"},
                    "message": {"type": "string"},
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {"type": "string"}
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Đăng ký khách hàng",
        "description": "Khách hàng tự đăng ký tài khoản (username = phone)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["phone", "password", "name"],
                "properties": {
                  "phone": {"type": "string", "example": "0987654321"},
                  "password": {"type": "string", "example": "Pass@123"},
                  "name": {"type": "string", "example": "Nguyễn Văn A"},
                  "email": {"type": "string", "example": "email@example.com"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Đăng ký thành công"}
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Thông tin user hiện tại",
        "description": "Lấy thông tin user đang đăng nhập",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "Success"}
        }
      }
    },
    "/auth/change-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Đổi mật khẩu",
        "description": "User đổi mật khẩu của chính mình (yêu cầu đăng nhập)",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["old_password", "new_password"],
                "properties": {
                  "old_password": {"type": "string", "example": "OldPass@123"},
                  "new_password": {"type": "string", "example": "NewPass@456", "description": "Mật khẩu mới phải đủ mạnh (8+ ký tự, có chữ hoa, chữ thường, số, ký tự đặc biệt)"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Đổi mật khẩu thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean"},
                    "message": {"type": "string"}
                  }
                }
              }
            }
          },
          "400": {"description": "Mật khẩu cũ không đúng hoặc mật khẩu mới không đủ mạnh"},
          "401": {"description": "Chưa đăng nhập"}
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Quên mật khẩu",
        "description": "Gửi mật khẩu mới qua email (tìm user bằng số điện thoại)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["phone"],
                "properties": {
                  "phone": {"type": "string", "example": "0123456789", "description": "Số điện thoại đã đăng ký"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email đã được gửi",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean"},
                    "message": {"type": "string"},
                    "data": {
                      "type": "object",
                      "properties": {
                        "email": {"type": "string", "description": "Email đã được mask (e***e@gmail.com)"}
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {"description": "Số điện thoại không tồn tại hoặc chưa có email"}
        }
      }
    },
    "/password-requirements": {
      "get": {
        "tags": ["Auth"],
        "summary": "Yêu cầu mật khẩu",
        "description": "Lấy các yêu cầu về mật khẩu mạnh",
        "responses": {
          "200": {"description": "Success"}
        }
      }
    },
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Danh sách users",
        "description": "Lấy danh sách users (Admin only)",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}},
          {"name": "role", "in": "query", "schema": {"type": "string"}},
          {"name": "username", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Tạo user mới",
        "description": "Admin tạo tài khoản Staff/Admin",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password", "role"],
                "properties": {
                  "username": {"type": "string"},
                  "password": {"type": "string"},
                  "role": {"type": "string", "enum": ["ADMIN", "STAFF"]}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Tạo user thành công"}
        }
      }
    },
    "/users/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Chi tiết user",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Cập nhật user",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {"type": "string"},
                  "password": {"type": "string"},
                  "role": {"type": "string"},
                  "status": {"type": "integer"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Cập nhật thành công"}
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Xóa user",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Xóa thành công"}
        }
      }
    },
    "/customers": {
      "get": {
        "tags": ["Customers"],
        "summary": "Danh sách khách hàng",
        "description": "Lấy danh sách khách hàng (Admin/Staff)",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}},
          {"name": "name", "in": "query", "schema": {"type": "string"}},
          {"name": "phone", "in": "query", "schema": {"type": "string"}},
          {"name": "email", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      },
      "post": {
        "tags": ["Customers"],
        "summary": "Tạo khách hàng mới",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["phone", "password", "name"],
                "properties": {
                  "phone": {"type": "string"},
                  "password": {"type": "string"},
                  "name": {"type": "string"},
                  "email": {"type": "string"},
                  "points": {"type": "integer"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Tạo khách hàng thành công"}
        }
      }
    },
    "/customers/{id}": {
      "get": {
        "tags": ["Customers"],
        "summary": "Chi tiết khách hàng",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      },
      "put": {
        "tags": ["Customers"],
        "summary": "Cập nhật khách hàng",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "phone": {"type": "string"},
                  "email": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Cập nhật thành công"}
        }
      },
      "delete": {
        "tags": ["Customers"],
        "summary": "Vô hiệu hóa khách hàng",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Vô hiệu hóa thành công"}
        }
      }
    },
    "/customers/{id}/status": {
      "put": {
        "tags": ["Customers"],
        "summary": "Cập nhật trạng thái khách hàng",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {"type": "integer", "enum": [0, 1]}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Cập nhật trạng thái thành công"}
        }
      }
    },
    "/customers/{id}/points": {
      "put": {
        "tags": ["Customers"],
        "summary": "Cập nhật điểm tích lũy",
        "description": "Cộng/trừ/set điểm cho khách hàng",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action", "points"],
                "properties": {
                  "action": {"type": "string", "enum": ["add", "subtract", "set"]},
                  "points": {"type": "integer"},
                  "description": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Cập nhật điểm thành công"}
        }
      }
    },
    "/customers/{id}/points/history": {
      "get": {
        "tags": ["Customers"],
        "summary": "Lịch sử điểm của khách hàng",
        "description": "Admin/Staff xem lịch sử điểm",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}},
          {"name": "page", "in": "query", "schema": {"type": "integer"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      }
    },
    "/customers/profile": {
      "put": {
        "tags": ["Customers"],
        "summary": "Cập nhật profile của chính mình",
        "description": "Customer tự cập nhật thông tin",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "email": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Cập nhật thành công"}
        }
      }
    },
    "/customers/my-points/history": {
      "get": {
        "tags": ["Customers"],
        "summary": "Lịch sử điểm của tôi",
        "description": "Customer xem lịch sử điểm của mình",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      }
    },
    "/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "Danh sách danh mục (có phân trang)",
        "description": "Admin/Staff xem danh mục",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}},
          {"name": "search", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      },
      "post": {
        "tags": ["Categories"],
        "summary": "Tạo danh mục mới",
        "description": "Admin/Staff tạo danh mục",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {"type": "string", "example": "Mỳ cay"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Tạo danh mục thành công"}
        }
      }
    },
    "/categories/all": {
      "get": {
        "tags": ["Categories"],
        "summary": "Lấy tất cả danh mục",
        "description": "Public API - lấy tất cả không phân trang",
        "responses": {
          "200": {"description": "Success"}
        }
      }
    },
    "/categories/{id}": {
      "get": {
        "tags": ["Categories"],
        "summary": "Chi tiết danh mục",
        "description": "Admin/Staff xem chi tiết",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      },
      "put": {
        "tags": ["Categories"],
        "summary": "Cập nhật danh mục",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Cập nhật thành công"}
        }
      },
      "delete": {
        "tags": ["Categories"],
        "summary": "Xóa danh mục",
        "description": "Admin only - Không cho xóa nếu đang có sản phẩm",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Xóa thành công"}
        }
      }
    },
    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "Danh sách sản phẩm",
        "description": "Public API - Lấy danh sách sản phẩm với filter",
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer"}},
          {"name": "per_page", "in": "query", "schema": {"type": "integer"}},
          {"name": "category_id", "in": "query", "schema": {"type": "integer"}, "description": "Lọc theo danh mục"},
          {"name": "status", "in": "query", "schema": {"type": "integer", "enum": [0, 1]}, "description": "Lọc theo trạng thái"},
          {"name": "search", "in": "query", "schema": {"type": "string"}, "description": "Tìm kiếm theo tên"},
          {"name": "low_stock", "in": "query", "schema": {"type": "integer", "enum": [0, 1]}, "description": "Lọc sản phẩm sắp hết hàng"}
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Tạo sản phẩm mới",
        "description": "Admin/Staff tạo sản phẩm - Hỗ trợ upload nhiều ảnh",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["name", "price"],
                "properties": {
                  "category_id": {"type": "integer", "example": 1},
                  "name": {"type": "string", "example": "Mỳ cay level 1"},
                  "price": {"type": "number", "example": 50000},
                  "description": {"type": "string", "example": "Mỳ cay độ 1"},
                  "stock_quantity": {"type": "integer", "example": 100},
                  "min_stock": {"type": "integer", "example": 10},
                  "status": {"type": "integer", "enum": [0, 1], "default": 1},
                  "images": {
                    "type": "array",
                    "items": {"type": "string", "format": "binary"},
                    "description": "Upload nhiều ảnh (jpg, png, gif, webp, max 5MB/file)"
                  }
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "price"],
                "properties": {
                  "category_id": {"type": "integer", "example": 1},
                  "name": {"type": "string", "example": "Mỳ cay level 1"},
                  "price": {"type": "number", "example": 50000},
                  "description": {"type": "string"},
                  "image_url": {"type": "string", "description": "Hoặc dùng URL có sẵn"},
                  "stock_quantity": {"type": "integer", "example": 100},
                  "min_stock": {"type": "integer", "example": 10},
                  "status": {"type": "integer", "enum": [0, 1], "default": 1}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Tạo sản phẩm thành công"}
        }
      }
    },
    "/products/low-stock": {
      "get": {
        "tags": ["Products"],
        "summary": "Sản phẩm sắp hết hàng",
        "description": "Lấy danh sách sản phẩm có stock <= min_stock (Admin/Staff)",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {"description": "Success"}
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Chi tiết sản phẩm",
        "description": "Public API",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Success"}
        }
      },
      "put": {
        "tags": ["Products"],
        "summary": "Cập nhật sản phẩm",
        "description": "Admin/Staff cập nhật - Hỗ trợ upload nhiều ảnh mới",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "category_id": {"type": "integer"},
                  "name": {"type": "string"},
                  "price": {"type": "number"},
                  "description": {"type": "string"},
                  "stock_quantity": {"type": "integer"},
                  "min_stock": {"type": "integer"},
                  "status": {"type": "integer", "enum": [0, 1]},
                  "images": {
                    "type": "array",
                    "items": {"type": "string", "format": "binary"},
                    "description": "Upload ảnh mới (sẽ xóa ảnh cũ)"
                  }
                }
              }
            },
            "application/json": {
              "schema": {
