{
  "openapi": "3.0.0",
  "info": {
    "title": "Spicy Noodle Management API",
    "description": "REST API cho hệ thống quản lý nhà hàng mỳ cay",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/api",
      "description": "Development server"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Health check endpoints"
    },
    {
      "name": "Auth",
      "description": "Authentication endpoints"
    },
    {
      "name": "Products",
      "description": "Product management"
    },
    {
      "name": "Categories",
      "description": "Category management"
    },
    {
      "name": "Orders",
      "description": "Order management"
    },
    {
      "name": "Customers",
      "description": "Customer management"
    },
    {
      "name": "Tables",
      "description": "Table management"
    },
    {
      "name": "Branches",
      "description": "Branch management"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Kiểm tra trạng thái API",
        "responses": {
          "200": {
            "description": "API đang hoạt động",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Spicy Noodle API is running"
                    },
                    "version": {
                      "type": "string",
                      "example": "1.0.0"
                    },
                    "timestamp": {
                      "type": "string",
                      "example": "2024-01-01 12:00:00"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/test-db": {
      "get": {
        "tags": ["Health"],
        "summary": "Test database connection",
        "description": "Kiểm tra kết nối database",
        "responses": {
          "200": {
            "description": "Kết nối database thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Database connection successful"
                    },
                    "database": {
                      "type": "string",
                      "example": "spicy_noodle_db"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Error message"
          },
          "errors": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "Success": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Success message"
          },
          "data": {
            "type": "object",
            "nullable": true
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
